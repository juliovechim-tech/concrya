DATABASE_URL=sqlite:///./aion.db

# Autenticação por cookie HttpOnly (substitui AION_API_KEY — a chave nunca vai ao browser)
AION_SESSION_SECRET=change-me-in-production
AION_LOGIN_USER=admin
AION_LOGIN_PASS=admin123

# Planta padrão (usada pelo job semanal)
AION_PLANT_ID=PLANTA-01

# Modelo de calibração padrão
DEFAULT_MODEL=arrhenius
DEFAULT_FC_INF=55.0
DEFAULT_K=0.25

# Thresholds de alerta
DRIFT_THRESHOLD_MPA=2.0
DRIFT_CRITICAL_MPA=4.0
NC_CRITICAL_DELTA_MPA=3.0
