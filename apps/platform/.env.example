# ── CONCRYA Platform — Variáveis de Ambiente ────────────────────

# DB (Railway MySQL ou local)
DATABASE_URL=mysql://user:password@host:3306/concrya

# Server
NODE_ENV=production
PORT=3004

# OAuth
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=

# Analytics (opcional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Railway (auto-populado pelo Railway)
RAILWAY_ENVIRONMENT=production
